{
  "extends": "@adonisjs/tsconfig/tsconfig.client.json",
  "compilerOptions": {
    // WARN: set ignoreDeprecations to avoid error on baseUrl (deprecated in TS 7.0)
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "jsx": "preserve",
    "module": "ESNext",
    "jsxImportSource": "vue",
    "paths": {
      "~/*": ["./*"],
      "@generated/*": ["../.adonisjs/client/*"],
      "#build/ui": ["../node_modules/.nuxt-ui/ui"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.vue",
    "../.adonisjs/client/**/*.ts",
    "../.adonisjs/server/**/*.ts",
    "../auto-imports.d.ts",
    "../components.d.ts"
  ]
}
