<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- HTML meta -->
  <title inertia>VOT'ASSO</title>
  <meta name="description" content="Parce c'est aussi VOTRE asso." />

  <!-- google / search engine -->
  <meta itemprop="name" content="VOT'ASSO" />
  <meta itemprop="description" content="Parce c'est aussi VOTRE asso." />
  <meta itemprop="image" content="https://vot-asso.hirodev.fr/images/og_image.png" />

  <!-- facebook -->
  <meta property="og:url" content="https://vot-asso.hirodev.fr/" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="VOT'ASSO" />
  <meta property="og:description" content="Parce c'est aussi VOTRE asso." />
  <meta property="og:image" content="https://vot-asso.hirodev.fr/images/og_image.png" />

  <!-- twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="VOT'ASSO" />
  <meta name="twitter:description" content="Parce c'est aussi VOTRE asso." />
  <meta name="twitter:image" content="https://vot-asso.hirodev.fr/images/og_image.png" />

  <!-- favicon -->
  <link rel="icon" type="image/x-icon" href="https://vot-asso.hirodev.fr/assets/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="https://vot-asso.hirodev.fr/assets/icons/icon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="https://vot-asso.hirodev.fr/assets/icons/icon-16.png">

  <!-- apple icon -->
  <link rel="apple-touch-icon" sizes="180x180" href="https://vot-asso.hirodev.fr/assets/icons/icon-180.png">

  <!-- PWA manifest -->
  <link rel="manifest" href="https://vot-asso.hirodev.fr/assets/site.webmanifest">
  <meta name="theme-color" content="#e60000">

  @vite(['inertia/app.ts'])
  @inertiaHead()
  @stack('dumper')
  <script>
    const theme = localStorage.getItem('vueuse-color-scheme') || 'auto'
    if (theme === 'dark' || (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark')
    } else {
      document.documentElement.classList.remove('dark')
    }
  </script>
</head>

<body>
  <div id="splash-screen"
    class="fixed inset-0 z-9999 flex flex-col items-center justify-center transition-opacity duration-500 ease-in-out opacity-100">
    <h1 class="animate-pulse text-4xl">
      Chargement...
    </h1>
  </div>
  @inertia({ class: 'isolate' })
</body>

</html>
